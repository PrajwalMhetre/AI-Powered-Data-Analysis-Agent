# AI Provider Options: openai, anthropic, ollama
LLM_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Anthropic settings
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229

# Ollama Settings (For local, no-data-leak processing)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# Security
# Set to 'true' to block any commands that try to import OS or sys or do destructive file actions.
RESTRICT_FILE_OPERATIONS=true
